VERSION 5.7 ;
  NOWIREEXTENSIONATPIN ON ;
  DIVIDERCHAR "/" ;
  BUSBITCHARS "[]" ;
MACRO counter_top
  CLASS BLOCK ;
  FOREIGN counter_top ;
  ORIGIN 0.000 0.000 ;
  SIZE 80.000 BY 80.000 ;
  PIN VGND
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER Metal2 ;
        RECT 3.560 4.340 5.560 75.040 ;
    END
    PORT
      LAYER Metal2 ;
        RECT 74.120 4.340 76.120 75.040 ;
    END
    PORT
      LAYER Metal3 ;
        RECT 3.560 4.340 76.120 6.340 ;
    END
    PORT
      LAYER Metal3 ;
        RECT 3.560 73.040 76.120 75.040 ;
    END
    PORT
      LAYER Metal2 ;
        RECT 23.060 4.340 24.060 75.040 ;
    END
    PORT
      LAYER Metal3 ;
        RECT 3.560 26.340 76.120 28.340 ;
    END
  END VGND
  PIN VPWR
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER Metal2 ;
        RECT 6.560 7.340 8.560 72.040 ;
    END
    PORT
      LAYER Metal2 ;
        RECT 71.120 7.340 73.120 72.040 ;
    END
    PORT
      LAYER Metal3 ;
        RECT 6.560 7.340 73.120 9.340 ;
    END
