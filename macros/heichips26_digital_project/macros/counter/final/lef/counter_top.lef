        RECT 24.270 72.250 73.540 75.250 ;
        RECT 24.270 13.715 70.910 72.250 ;
        RECT 73.330 13.715 73.540 72.250 ;
      LAYER Metal3 ;
        RECT 0.400 72.250 70.705 72.760 ;
        RECT 0.400 69.830 6.350 72.250 ;
        RECT 0.400 66.350 70.705 69.830 ;
        RECT 0.610 65.530 70.705 66.350 ;
