library (counter) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1uA";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 25.0;
  nom_voltage                    : 1.20;

  type ("count_o") {
    base_type : array;
    data_type : bit;
    bit_width : 8;
    bit_from : 7;
    bit_to : 0;
  }

  cell ("counter") {
    area : 5171.024 
    is_macro_cell : true;
    pin("clk_i") {
      direction : input;
      capacitance : 0.0028;
    }
    pin("enable_i") {
      direction : input;
      capacitance : 0.0031;
    }
    pin("rst_ni") {
      direction : input;
      capacitance : 0.0032;
    }
    bus("count_o") {
      bus_type : count_o;
      direction : output;
      capacitance : 0.0000;
    pin("count_o[7]") {
      direction : output;
      capacitance : 0.0005;
    }
    pin("count_o[6]") {
      direction : output;
      capacitance : 0.0006;
    }
    pin("count_o[5]") {
      direction : output;
      capacitance : 0.0005;
    }
    pin("count_o[4]") {
      direction : output;
      capacitance : 0.0005;
    }
    pin("count_o[3]") {
      direction : output;
      capacitance : 0.0005;
    }
    pin("count_o[2]") {
      direction : output;
      capacitance : 0.0005;
    }
    pin("count_o[1]") {
      direction : output;
      capacitance : 0.0005;
    }
    pin("count_o[0]") {
      direction : output;
      capacitance : 0.0005;
    }
    }
  }

}
